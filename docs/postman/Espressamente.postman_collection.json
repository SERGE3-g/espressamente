{
  "info": {
    "name": "Espressamente API v2.0.0",
    "_postman_id": "espressamente-api-v2",
    "description": "API Espressamente Coffee — Spring Boot 3.4.3\n\n## Autenticazione OAuth 2.0 (Password Grant)\n1. Seleziona l'environment (Local / Staging / Production)\n2. Tab **Authorization** → clicca **Get New Access Token**\n3. Il token viene aggiunto automaticamente a tutte le richieste admin\n\n`{{baseUrl}}` si adatta all'environment selezionato.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "oauth2",
    "oauth2": [
      { "key": "grant_type", "value": "password_credentials", "type": "string" },
      { "key": "accessTokenUrl", "value": "{{baseUrl}}/v1/auth/token", "type": "string" },
      { "key": "username", "value": "{{adminUsername}}", "type": "string" },
      { "key": "password", "value": "{{adminPassword}}", "type": "string" },
      { "key": "clientId", "value": "", "type": "string" },
      { "key": "clientSecret", "value": "", "type": "string" },
      { "key": "scope", "value": "", "type": "string" },
      { "key": "tokenName", "value": "Espressamente JWT", "type": "string" },
      { "key": "headerPrefix", "value": "Bearer", "type": "string" },
      { "key": "addTokenTo", "value": "header", "type": "string" },
      { "key": "client_authentication", "value": "body", "type": "string" },
      { "key": "useBrowser", "value": false, "type": "boolean" }
    ]
  },
  "event": [],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Autenticazione — login, refresh, logout, password reset.\nIl login manuale NON è necessario se usi OAuth 2.0 a livello collection.",
      "item": [
        {
          "name": "Login (manuale)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "login"] }
          }
        },
        {
          "name": "OAuth2 Token (usato da Postman)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password", "type": "text" },
                { "key": "username", "value": "{{adminUsername}}", "type": "text" },
                { "key": "password", "value": "{{adminPassword}}", "type": "text" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/v1/auth/token", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "token"] },
            "description": "Endpoint OAuth 2.0 Password Grant. Postman lo chiama automaticamente tramite \"Get New Access Token\"."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "refresh"] },
            "description": "Richiede cookie httpOnly refresh_token (settato automaticamente dal login)."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "logout"] }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@espressamente.eu\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/v1/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "forgot-password"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"NuovaPassword123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/v1/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "reset-password"] }
          }
        }
      ]
    },
