{
  "info": {
    "name": "Espressamente API v2.0.0",
    "_postman_id": "espressamente-api-v2",
    "description": "Collezione completa delle API Espressamente Coffee — Backend Spring Boot 3.4.3\n\n**Autenticazione:** JWT Bearer Token\n- Esegui `Auth / Login` → il token viene salvato automaticamente in `accessToken`\n- Tutte le richieste admin usano `{{accessToken}}` nell'header Authorization\n\n**Base URL:** `{{baseUrl}}`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "oauth2",
    "oauth2": [
      {
        "key": "grant_type",
        "value": "password_credentials",
        "type": "string"
      },
      {
        "key": "accessTokenUrl",
        "value": "{{baseUrl}}/v1/auth/token",
        "type": "string"
      },
      {
        "key": "username",
        "value": "{{adminUsername}}",
        "type": "string"
      },
      {
        "key": "password",
        "value": "{{adminPassword}}",
        "type": "string"
      },
      {
        "key": "clientId",
        "value": "",
        "type": "string"
      },
      {
        "key": "clientSecret",
        "value": "",
        "type": "string"
      },
      {
        "key": "scope",
        "value": "",
        "type": "string"
      },
      {
        "key": "tokenName",
        "value": "Espressamente JWT",
        "type": "string"
      },
      {
        "key": "addTokenTo",
        "value": "header",
        "type": "string"
      },
      {
        "key": "headerPrefix",
        "value": "Bearer",
        "type": "string"
      },
      {
        "key": "client_authentication",
        "value": "body",
        "type": "string"
      },
      {
        "key": "useBrowser",
        "value": false,
        "type": "boolean"
      },
      {
        "key": "authUrl",
        "value": "",
        "type": "string"
      },
      {
        "key": "redirect_uri",
        "value": "",
        "type": "string"
      },
      {
        "key": "state",
        "value": "",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-login se accessToken mancante o scaduto",
          "const token = pm.environment.get('accessToken');",
          "if (token) return;",
          "",
          "const baseUrl = pm.environment.get('baseUrl') || pm.variables.get('baseUrl');",
          "const username = pm.environment.get('adminUsername') || 'admin';",
          "const password = pm.environment.get('adminPassword');",
          "",
          "if (!password) {",
          "    console.warn('⚠️  adminPassword non impostata nell\\'environment — imposta la variabile e riprova.');",
          "    return;",
          "}",
          "",
          "pm.sendRequest({",
          "    url: baseUrl + '/v1/auth/login',",
          "    method: 'POST',",
          "    header: { 'Content-Type': 'application/json' },",
          "    body: { mode: 'raw', raw: JSON.stringify({ username, password }) }",
          "}, (err, res) => {",
          "    if (err) { console.error('Auto-login fallito:', err); return; }",
          "    const body = res.json();",
          "    if (body.data && body.data.accessToken) {",
          "        pm.environment.set('accessToken', body.data.accessToken);",
          "        pm.environment.set('currentUser', body.data.username);",
          "        pm.environment.set('currentRole', body.data.role);",
          "        console.log('✅ Auto-login OK: ' + body.data.username + ' (' + body.data.role + ')');",
          "    } else {",
          "        console.error('Auto-login: risposta inattesa', JSON.stringify(body));",
          "    }",
          "});"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string",
      "description": "Override tramite environment — non modificare qui"
    }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    if (body.data && body.data.accessToken) {",
                  "        pm.environment.set('accessToken', body.data.accessToken);",
                  "        pm.environment.set('currentUser', body.data.username);",
                  "        pm.environment.set('currentRole', body.data.role);",
                  "        console.log('✅ Token salvato per: ' + body.data.username + ' (' + body.data.role + ')');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "login"] }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    if (body.data && body.data.accessToken) {",
                  "        pm.environment.set('accessToken', body.data.accessToken);",
                  "        console.log('✅ Token rinnovato');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "refresh"] },
            "description": "Richiede il cookie `refresh_token` (httpOnly). Funziona automaticamente nel browser/Postman se il cookie è presente."
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.unset('accessToken');",
                  "pm.environment.unset('currentUser');",
                  "pm.environment.unset('currentRole');",
                  "console.log('✅ Logout effettuato, token rimosso');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["v1", "auth", "logout"] }
          }
        },
        {
          "name": "Forgot Password",
