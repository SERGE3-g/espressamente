# pgpass — credenziali per pgAdmin (formato: host:porta:database:utente:password)
# Copia questo file in pgpass e riempi le password reali.
# Il file pgpass NON deve essere committato in git.
#
# Staging espressamente
host.docker.internal:5434:espressamente_db:sergeguea:LA_TUA_PASSWORD_STAGING
# Produzione espressamente
host.docker.internal:5433:espressamente_db:sergeguea:LA_TUA_PASSWORD_PROD
# JurixSuite dev
host.docker.internal:5432:*:postgres:LA_TUA_PASSWORD_JURIXSUITE
