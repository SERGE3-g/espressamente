# ─────────────────────────────────────────────────────────────────────────────
# Template variabili d'ambiente per la produzione
# Copia in .env.production e compila i valori reali
# MAI committare .env.production nel repository!
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_USERNAME=espressamente
DB_PASSWORD=CAMBIA_QUESTA_PASSWORD_SICURA

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera con: openssl rand -base64 64
JWT_SECRET=CAMBIA_QUESTA_CHIAVE_SEGRETA_ALMENO_256_BIT

# ── Mail (SMTP produzione) ────────────────────────────────────────────────────
MAIL_HOST=smtp.esempio.it
MAIL_PORT=587
MAIL_USERNAME=info@espressamente.it
MAIL_PASSWORD=CAMBIA_PASSWORD_MAIL
NOTIFICATION_EMAIL=info@espressamente.it

# ── Storage ───────────────────────────────────────────────────────────────────
# "local" = uploads in /app/uploads (volume Docker)
# "s3"    = AWS S3 o MinIO compatibile
STORAGE_TYPE=local

# Se STORAGE_TYPE=s3, decommenta e compila:
# S3_BUCKET=espressamente-media
# S3_REGION=eu-south-1
# S3_ENDPOINT=https://s3.amazonaws.com   # oppure URL MinIO
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ── Tag immagine Docker (opzionale) ──────────────────────────────────────────
# TAG=latest  # oppure TAG=abc1234 per una versione specifica
