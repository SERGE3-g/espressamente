# ─────────────────────────────────────────────────────────────────────────────
# Template variabili d'ambiente per lo staging (stg.espressamente.eu)
# Copia in .env.staging e compila i valori reali
# MAI committare .env.staging nel repository!
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_USERNAME=espressamente_staging
DB_PASSWORD=CAMBIA_QUESTA_PASSWORD_STAGING

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera con: openssl rand -base64 64
JWT_SECRET=CAMBIA_QUESTA_CHIAVE_JWT_STAGING

# ── Mail (può usare lo stesso SMTP della prod oppure MailHog/Mailtrap) ────────
MAIL_HOST=smtp.esempio.it
MAIL_PORT=587
MAIL_USERNAME=no-reply@espressamente.eu
MAIL_PASSWORD=CAMBIA_PASSWORD_MAIL
NOTIFICATION_EMAIL=dev@espressamente.eu

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_TYPE=local

# ── Tag immagine Docker ───────────────────────────────────────────────────────
TAG=staging
REPO_OWNER=serge3-g
